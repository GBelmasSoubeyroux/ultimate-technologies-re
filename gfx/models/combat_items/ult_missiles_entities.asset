@missile_scale = 1.0

# MISSILES


entity = {
	name = "void_phase_missile_energy_entity"
	pdxmesh = "arthropoid_01_missile_mesh"
	
	default_state = idle
	state = { name = "idle" animation = "idle"
		start_event = { time = 0 node = exhaust particle = "void_phase_missile_energy_idle_particle" keep_particle = yes }
		start_event = { trigger_once = yes time = 0 node = exhaust particle = "void_phase_missile_energy_idle_flame_particle" keep_particle = yes }
	}
	state = { name = "stop"
		looping = no
		#state_time = 2.0
		chance = 1
		animation = "miss"
		time_offset = { 0 1.4 }
		animation_blend_time = 0.5
		#start_event = { time = 0 node = exhaust particle = "void_phase_missile_energy_idle_particle" keep_particle = yes }
		start_event = { trigger_once = yes time = 0 node = exhaust particle = "void_phase_missile_energy_idle_flame_particle" keep_particle = yes }
	}
	state = { name = "stop"
		looping = no
		#state_time = 2.0
		chance = 1
		animation = "miss2"
		time_offset = { 0 1 }
		animation_blend_time = 0.5
		#start_event = { time = 0 node = exhaust particle = "void_phase_missile_energy_idle_particle" keep_particle = yes }
		start_event = { trigger_once = yes time = 0 node = exhaust particle = "void_phase_missile_energy_idle_flame_particle" keep_particle = yes }
	}
	state = { name = "stop"
		looping = no
		#state_time = 2.0
		chance = 1
		animation = "miss_reversed"
		time_offset = { 0 1.4 }
		animation_blend_time = 0.5
		#start_event = { time = 0 node = exhaust particle = "void_phase_missile_energy_idle_particle" keep_particle = yes }
		start_event = { trigger_once = yes time = 0 node = exhaust particle = "void_phase_missile_energy_idle_flame_particle" keep_particle = yes }
	}
	state = { name = "stop"
		looping = no
		#state_time = 2.0
		chance = 1
		animation = "miss2_reversed"
		time_offset = { 0 1 }
		animation_blend_time = 0.5
		#start_event = { time = 0 node = exhaust particle = "void_phase_missile_energy_idle_particle" keep_particle = yes }
		start_event = { trigger_once = yes time = 0 node = exhaust particle = "void_phase_missile_energy_idle_flame_particle" keep_particle = yes }
	}
	scale = 2
}

