
# PROJECTILE

entity = {
	name = "phase_railgun_muzzle_entity"
	cull_radius = 1.0
	
	default_state = "idle"
	state = { name = "idle" state_time = 0.3 looping = no
		event = { time = 0 particle = "xray_laser_large_muzzle_particle" keep_particle = yes sound = { soundeffect = adv_kinectic_fire } }
		event = { trigger_once = yes sound = { soundeffect = "distance_adv_kinectic_fire" } }
	}
}

entity = {
	name = "singularity_accelerator_muzzle_entity"
	cull_radius = 1.0
	
