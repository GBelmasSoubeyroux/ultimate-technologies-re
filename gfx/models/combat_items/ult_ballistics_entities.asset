		event = { time = 0 particle = "focused_arc_emitter_muzzle_particle" keep_particle = yes sound = { soundeffect = adv_kinectic_fire } }
		event = { trigger_once = yes sound = { soundeffect = "distance_adv_kinectic_fire" } }
